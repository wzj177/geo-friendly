#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * Geo-Friendly CLI
 *
 * This is the main entry point for the Geo-Friendly command-line interface.
 */

foreach ([__DIR__ . '/../../autoload.php', __DIR__ . '/../vendor/autoload.php'] as $file) {
    if (file_exists($file)) {
        require $file;
        break;
    }
}

use GeoFriendly\CLI\Application;

$app = new Application();
$app->run();
