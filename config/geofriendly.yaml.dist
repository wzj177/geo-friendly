# Geo-Friendly Configuration File
# Copy this file to geofriendly.yaml and customize for your site

# Basic site information
title: 'My Site'
url: 'https://example.com'
description: 'A description of your site for AI engines'

# Directory configuration
outDir: './public'
contentDir: './content'

# Generator configuration
# Each generator can be enabled (true) or disabled (false)
generators:
  robotsTxt: true      # Generate robots.txt with AI-specific directives
  llmsTxt: true        # Generate llms.txt (AI discovery)
  llmsFullTxt: true    # Generate comprehensive llms-full.txt
  rawMarkdown: true    # Generate raw markdown files for AI ingestion
  manifest: true       # Generate AI-friendly manifest
  sitemap: true        # Generate XML sitemap
  aiIndex: true        # Generate AI index files
  schema: true         # Generate JSON-LD schema markup

# Robots.txt configuration
# Additional rules to include in robots.txt
robots:
  - 'User-agent: *'
  - 'Allow: /'

# Widget configuration
# Customize the appearance of Geo-Friendly widgets
widget:
  color: '#0066cc'
  position: 'bottom-right'
  size: 'medium'

# Schema.org configuration
# Configure default schema types and properties
schema:
  '@type': 'WebSite'
  '@context': 'https://schema.org'

# Open Graph configuration
# Configure Open Graph meta tags
og:
  type: 'website'
  siteName: 'My Site'

# Firecrawl configuration
# Use Firecrawl API to crawl and extract website content
# Get your API key from: https://www.firecrawl.dev/
firecrawl:
  # API key for Firecrawl (leave empty to disable Firecrawl)
  # Set via environment variable: FIRECRAWL_API_KEY
  apiKey: '%env(FIRECRAWL_API_KEY)%'

  # Base URL for Firecrawl API
  # Default: https://api.firecrawl.dev/v1
  # Change only if using a custom endpoint or proxy
  apiUrl: 'https://api.firecrawl.dev/v1'

  # Enable Firecrawl for content extraction
  # When enabled (apiKey is set), geo-friendly will crawl URLs instead of reading local files
  # This is useful for dynamic websites (WordPress, Shopify, custom PHP apps, etc.)
  enabled: true

# OpenAI configuration
# Use OpenAI API for AI-powered content enhancement
# Get your API key from: https://platform.openai.com/api-keys
openai:
  # API key for OpenAI (leave empty to disable AI features)
  # Set via environment variable: OPENAI_API_KEY
  apiKey: '%env(OPENAI_API_KEY)%'

  # Base URL for OpenAI API
  # Default: https://api.openai.com/v1
  # Change if using OpenAI-compatible endpoint (Azure OpenAI, custom proxy, etc.)
  baseUrl: 'https://api.openai.com/v1'

  # Model to use for AI features
  # Options: gpt-4o-mini (recommended, cost-effective), gpt-4o (better quality)
  model: 'gpt-4o-mini'

  # Enable AI enhancement features
  # When enabled (apiKey is set), content will be AI-optimized for better GEO
  # Features: better descriptions, keyword extraction, SEO optimization
  enabled: true
