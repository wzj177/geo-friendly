{
  "name": "aeojs-demo-angular",
  "private": true,
  "scripts": {
    "dev": "ng serve --port 3400",
    "build": "ng build && node --input-type=module -e \"import {postBuild} from 'aeo.js/angular'; postBuild({title:'AEO Demo Site',description:'A demo site showcasing aeo.js with Angular',url:'https://demo.aeojs.org'});\"",
    "start": "ng serve"
  },
  "dependencies": {
    "@angular/animations": "^17.0.0",
    "@angular/common": "^17.0.0",
    "@angular/compiler": "^17.0.0",
    "@angular/core": "^17.0.0",
    "@angular/forms": "^17.0.0",
    "@angular/platform-browser": "^17.0.0",
    "@angular/platform-browser-dynamic": "^17.0.0",
    "@angular/router": "^17.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.0",
    "aeo.js": "file:../../"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.0.0",
    "@angular/cli": "^17.0.0",
    "@angular/compiler-cli": "^17.0.0",
    "typescript": "~5.2.0"
  }
}
