---
import Layout from '../layouts/Layout.astro';
import { PAGES } from '../../../shared/content';

const page = PAGES.faq;
---

<Layout title={page.title}>
  <h1>{page.heading}</h1>
  <p class="description">{page.description}</p>

  <div class="questions">
    {page.questions.map((item) => (
      <details>
        <summary>{item.question}</summary>
        <p>{item.answer}</p>
      </details>
    ))}
  </div>
</Layout>

<style>
  h1 {
    margin-bottom: 0.5rem;
  }

  .description {
    color: #555;
    margin-bottom: 1.5rem;
  }

  .questions {
    display: grid;
    gap: 0.75rem;
  }

  details {
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 1rem 1.25rem;
    background: #fff;
  }

  details[open] {
    border-color: #2563eb;
  }

  summary {
    font-weight: 600;
    cursor: pointer;
    font-size: 1rem;
    line-height: 1.5;
  }

  summary:hover {
    color: #2563eb;
  }

  details p {
    margin-top: 0.75rem;
    color: #555;
    font-size: 0.95rem;
    line-height: 1.7;
  }
</style>
