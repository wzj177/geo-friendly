---
import Layout from '../layouts/Layout.astro';
import { PAGES } from '../../../shared/content';

const page = PAGES.pricing;
---

<Layout title={page.title}>
  <h1>{page.heading}</h1>
  <p class="description">{page.description}</p>
  <p>{page.body}</p>

  <div class="tiers">
    {page.tiers.map((tier) => (
      <div class="tier">
        <h2>{tier.name}</h2>
        <p class="price">{tier.price}</p>
        <ul>
          {tier.features.map((feature) => (
            <li>{feature}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</Layout>

<style>
  h1 {
    margin-bottom: 0.5rem;
  }

  .description {
    color: #555;
    margin-bottom: 1rem;
  }

  .tiers {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .tier {
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 1.5rem;
    background: #fff;
  }

  .tier h2 {
    font-size: 1.15rem;
    margin-bottom: 0.25rem;
  }

  .price {
    font-size: 1.5rem;
    font-weight: 700;
    color: #2563eb;
    margin-bottom: 1rem;
  }

  .tier ul {
    padding-left: 1.25rem;
  }

  .tier li {
    margin-bottom: 0.4rem;
    font-size: 0.95rem;
    color: #555;
  }

  @media (max-width: 600px) {
    .tiers {
      grid-template-columns: 1fr;
    }
  }
</style>
