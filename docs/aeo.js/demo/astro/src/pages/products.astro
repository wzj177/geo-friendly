---
import Layout from '../layouts/Layout.astro';
import { PAGES } from '../../../shared/content';

const page = PAGES.products;
---

<Layout title={page.title}>
  <h1>{page.heading}</h1>
  <p class="description">{page.description}</p>
  <p>{page.body}</p>

  <div class="items">
    {page.items.map((item) => (
      <div class="item">
        <h3>{item.name}</h3>
        <p>{item.description}</p>
      </div>
    ))}
  </div>
</Layout>

<style>
  h1 {
    margin-bottom: 0.5rem;
  }

  .description {
    color: #555;
    margin-bottom: 1rem;
  }

  .items {
    margin-top: 1.5rem;
    display: grid;
    gap: 1rem;
  }

  .item {
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 1rem 1.25rem;
    background: #fff;
  }

  .item h3 {
    margin-bottom: 0.25rem;
    font-family: monospace;
    font-size: 1rem;
    color: #2563eb;
  }

  .item p {
    color: #555;
    font-size: 0.95rem;
  }
</style>
